{
  "name": "showcase",
  "version": "1.0.0",
  "description": "Azerbaijan GitHub Community — project showcase registry",
  "private": true,
  "type": "module",
  "scripts": {
    "checks": "tsx scripts/checks.ts",
    "validate": "tsx .github/scripts/validate.ts",
    "set-timestamps": "tsx .github/scripts/set-timestamps.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write projects/",
    "format:check": "prettier --check projects/"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.1",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-yaml": "^1.1.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
