{
  "name": "showcase",
  "version": "1.0.0",
  "description": "Azerbaijan GitHub Community — project showcase registry",
  "private": true,
  "type": "module",
  "scripts": {
    "checks": "node scripts/checks.ts",
    "validate": "node .github/scripts/validate.ts",
    "set-timestamps": "node .github/scripts/set-timestamps.ts",
    "format": "prettier --write projects/",
    "format:check": "prettier --check projects/"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "js-yaml": "4.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-yaml": "1.1.3",
    "typescript": "6.0.3"
  }
}
